{
  "name": "chromo",
  "version": "1.0.0",
  "description": "Powerful checkpoint tools with block-level deduplication",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run index.ts",
    "build": "bun build index.ts --compile --outfile chromo",
    "dev": "bun --watch index.ts",
    "test": "bun test"
  },
  "bin": {
    "chromo": "./index.ts"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.12",
    "blessed": "^0.1.81",
    "diff": "^5.1.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.21",
    "@types/bun": "^1.3.10",
    "@types/diff": "^5.0.9",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "checkpoint",
    "backup",
    "version-control",
    "deduplication",
    "time-travel"
  ],
  "author": "Chromo Team",
  "license": "MIT"
}
